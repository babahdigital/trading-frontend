# Database
DATABASE_URL="postgresql://trading_user:changeme_strong_password@db:5432/trading_commercial?schema=public"

# JWT
JWT_SECRET="changeme_generate_with_openssl_rand_base64_64"

# Admin seed
ADMIN_EMAIL="admin@babahalgo.com"
ADMIN_PASSWORD="changeme_admin_password"

# App
NEXT_PUBLIC_APP_URL="https://babahalgo.com"
NODE_ENV="production"

# License Middleware Master Key (AES-256-GCM for VPS admin token encryption)
# Generate: openssl rand -hex 32
LICENSE_MW_MASTER_KEY="changeme_generate_with_openssl_rand_hex_32"

# VPS1 Backend — commercial API (via SSH tunnel or direct)
# If using SSH reverse tunnel (recommended): VPS1_BACKEND_URL="http://127.0.0.1:18000"
VPS1_BACKEND_URL="http://127.0.0.1:18000"

# Scoped API tokens (optional — falls back to VPS1_ADMIN_TOKEN)
VPS1_ADMIN_TOKEN=""
VPS1_TOKEN_SIGNALS=""
VPS1_TOKEN_TRADE_EVENTS=""
VPS1_TOKEN_RESEARCH=""
VPS1_TOKEN_PAMM=""
VPS1_TOKEN_STATS=""
# Tenant-admin scope token — used by /api/client/whatsapp/config to PATCH
# /api/forex/tenant/whatsapp on behalf of authenticated user.
# Falls back to VPS1_ADMIN_TOKEN if empty.
VPS1_TOKEN_TENANT_ADMIN=""

# ============================================================
# Crypto Backend (trading-crypto FastAPI port 8100)
# ============================================================
# Set when crypto product is enabled. FE proxies /api/crypto/* and
# /api/client/crypto/notifications to this backend.
CRYPTO_BACKEND_URL=""
# Scoped tokens — backend assigns per-tenant tokens via X-API-Token.
# `keys` scope is required for notification preferences endpoint
# (per CRYPTO_2026_04_27_NOTIFICATION_PREFERENCES.md).
CRYPTO_TOKEN_SIGNALS=""
CRYPTO_TOKEN_TRADES=""
CRYPTO_TOKEN_KEYS=""
CRYPTO_TOKEN_ADMIN=""

# Cron secret for external schedulers (required to authenticate /api/cron/*)
# Generate: openssl rand -hex 32
CRON_SECRET="changeme_generate_with_openssl_rand_hex_32"

# In-process worker feature flags (1=on, 0=off)
ENABLE_SIGNAL_CONSUMER="0"
ENABLE_TRADE_EVENTS_CONSUMER="0"
ENABLE_RESEARCH_INGESTER="0"
ENABLE_PAIR_BRIEF_WORKER="0"

# Blog article generator — AI-powered topic catalog → articles (fully zero-touch)
#
# AUTO-ENABLED when OPENROUTER_API_KEY is configured. Worker auto-seeds
# the BlogTopic catalog on first run and generates articles every 12h
# per scheduledWeek (Week 1-4 rollout).
#
# Set ENABLE_BLOG_GENERATOR="0" explicitly to force-disable.
# Set ENABLE_BLOG_GENERATOR="1" explicitly to force-enable even without key
# (worker will no-op until key is present).
ENABLE_BLOG_GENERATOR=""
# Interval between generator runs in ms (default: 12h = 43200000)
BLOG_GENERATOR_INTERVAL_MS="43200000"
# ISO week of launch (format YYYY-Www) — topics with scheduledWeek <= (current - launch + 1) are eligible.
# Leave empty to use current week at process startup (auto).
BLOG_LAUNCH_EPOCH_ISO_WEEK=""

# Daily research auto-pipeline — generates 1 article per day with day-of-week
# rotation (Mon=recap, Tue=AI lesson, Wed=case study, Thu=correlation,
# Fri=risk, Sat=strategy, Sun=preview). Auto-enabled when OPENROUTER_API_KEY set.
ENABLE_DAILY_RESEARCH=""

# PostgreSQL (used by docker-compose)
POSTGRES_DB="trading_commercial"
POSTGRES_USER="trading_user"
POSTGRES_PASSWORD="changeme_strong_password"

# Cloudflare (for Vercel rewrites)
CF_ACCESS_CLIENT_ID=""
CF_ACCESS_CLIENT_SECRET=""

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_ADMIN_CHAT_ID=""
TEST_TELEGRAM_CHAT_ID=""

# ============================================================
# WhatsApp Notification (frontend portion)
# ============================================================
# Frontend NEVER sends WA messages to customers in production traffic.
# Backend forex/crypto own delivery. The token below is used only by:
#   - /api/client/whatsapp/validate (Fonnte /validate proxy — saves an OTP
#     send when target number is not registered on WhatsApp)
#   - /api/client/whatsapp/verify (forex OTP fallback when backend
#     /api/forex/internal/whatsapp/otp/send returns 404/405; crypto path
#     uses backend `/whatsapp/verify` directly so this fallback is unused
#     for the crypto product)
#
# Phase 1 decision (Abdullah, 2026-04-27): single shared Fonnte account
# for forex + crypto — set the same token here and on both backends.
# Get device token: https://fonnte.com → Devices → Token (no "Bearer" prefix).
FONNTE_TOKEN=""

# OTP hash secret for the FE-side WhatsappVerification table.
# Generate with: openssl rand -hex 32
# Falls back to JWT_SECRET if empty (acceptable for low-volume Phase 1, but
# rotating JWT_SECRET would invalidate every pending OTP — set this
# separately for production isolation).
WA_OTP_HASH_SECRET=""

# OpenRouter — single AI provider for everything: pair briefs, chat,
# translations, research body enhancement. Default model is
# google/gemini-2.5-flash-lite (cheap + fast).
OPENROUTER_API_KEY=""

# Email — Brevo API (recommended) or SMTP fallback
# Get API key: https://app.brevo.com → Settings → SMTP & API → API Keys
BREVO_API_KEY=""
# SMTP fallback (only used if BREVO_API_KEY is empty)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="BabahAlgo <no-reply@babahalgo.com>"

# Payment — Midtrans
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_MERCHANT_ID=""

# Payment — Xendit
XENDIT_SECRET_KEY=""
XENDIT_WEBHOOK_TOKEN=""

# Observability — Sentry
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ============================================================
# Cloudflare R2 backup (offsite disaster recovery)
# ============================================================
# Setup: dash.cloudflare.com → R2 → Create bucket + API token (Object R/W)
# Default disabled. Enable dengan set R2_ENABLED=true + isi credentials.
R2_ENABLED="false"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="babahalgo-backups"
# Prefix folder dalam bucket — biar terstruktur per-project (multi-project bucket).
# Contoh: R2_PREFIX=frontend → r2:bucket/frontend/backups + r2:bucket/frontend/public
# Kosong = di root bucket.
R2_PREFIX="frontend"
# Endpoint jurisdiction — kosong = default (US, auto-construct dari R2_ACCOUNT_ID).
# Untuk EU set: https://<account-id>.eu.r2.cloudflarestorage.com
R2_ENDPOINT=""

# Schedule overrides (optional)
# Default: daily DB backup sync ke R2 jam 03:00, weekly public folder sync Sunday 04:00 Asia/Jakarta
BACKUP_SYNC_HOUR="3"
PUBLIC_SYNC_HOUR="4"
PUBLIC_SYNC_DOW="7"
