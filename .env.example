# Database
DATABASE_URL="postgresql://trading_user:changeme_strong_password@db:5432/trading_commercial?schema=public"

# JWT
JWT_SECRET="changeme_generate_with_openssl_rand_base64_64"

# Admin seed
ADMIN_EMAIL="admin@babahalgo.com"
ADMIN_PASSWORD="changeme_admin_password"

# App
NEXT_PUBLIC_APP_URL="https://babahalgo.com"
NODE_ENV="production"

# License Middleware Master Key (AES-256-GCM for VPS admin token encryption)
# Generate: openssl rand -hex 32
LICENSE_MW_MASTER_KEY="changeme_generate_with_openssl_rand_hex_32"

# VPS1 Backend — commercial API (via SSH tunnel or direct)
# If using SSH reverse tunnel (recommended): VPS1_BACKEND_URL="http://127.0.0.1:18000"
VPS1_BACKEND_URL="http://127.0.0.1:18000"

# Scoped API tokens (optional — falls back to VPS1_ADMIN_TOKEN)
VPS1_ADMIN_TOKEN=""
VPS1_TOKEN_SIGNALS=""
VPS1_TOKEN_TRADE_EVENTS=""
VPS1_TOKEN_RESEARCH=""
VPS1_TOKEN_PAMM=""
VPS1_TOKEN_STATS=""

# Cron secret for external schedulers (required to authenticate /api/cron/*)
# Generate: openssl rand -hex 32
CRON_SECRET="changeme_generate_with_openssl_rand_hex_32"

# In-process worker feature flags (1=on, 0=off)
ENABLE_SIGNAL_CONSUMER="0"
ENABLE_TRADE_EVENTS_CONSUMER="0"
ENABLE_RESEARCH_INGESTER="0"

# PostgreSQL (used by docker-compose)
POSTGRES_DB="trading_commercial"
POSTGRES_USER="trading_user"
POSTGRES_PASSWORD="changeme_strong_password"

# Cloudflare (for Vercel rewrites)
CF_ACCESS_CLIENT_ID=""
CF_ACCESS_CLIENT_SECRET=""

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_ADMIN_CHAT_ID=""
TEST_TELEGRAM_CHAT_ID=""

# Google AI (for Babah chat assistant & auto-translate)
GOOGLE_GENERATIVE_AI_API_KEY=""

# Email SMTP — Brevo (formerly Sendinblue) recommended
# Sign up: https://app.brevo.com → Settings → SMTP & API → SMTP
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="BabahAlgo <no-reply@babahalgo.com>"

# Payment — Midtrans
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_MERCHANT_ID=""

# Payment — Xendit
XENDIT_SECRET_KEY=""
XENDIT_WEBHOOK_TOKEN=""

# Observability — Sentry
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
