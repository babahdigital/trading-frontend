# ============================================================
# Customer VPS Environment Template
# Generated from template during provisioning
# DO NOT commit filled version to git
# ============================================================

# ─── Customer Identity ────────────────────────────────────
CUSTOMER_ID=CUST-XXXXX
CUSTOMER_LOCALE=id
TIER=TRADER  # STARTER | TRADER | PREMIUM | HNWI_CLUB

# ─── Code Versions ────────────────────────────────────────
CODE_VERSION=v1.6.51
LICENSE_MW_VERSION=latest
BOT_VERSION=latest

# ─── Database ─────────────────────────────────────────────
DB_USER=trader
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=trading

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─── API Authentication ───────────────────────────────────
ADMIN_TOKEN=CHANGE_ME_64_HEX_CHARS

# ─── VPS1 Master Sync ─────────────────────────────────────
VPS1_BASE_URL=https://api.babahalgo.com
SYNC_TOKEN=CHANGE_ME_FROM_VPS2_MINT
SYNC_INTERVAL_HOURS=24

# ─── VPS2 License Check ───────────────────────────────────
VPS2_LICENSE_URL=https://babahalgo.com/api/license/check
LICENSE_HMAC_SECRET=CHANGE_ME_MATCH_VPS2
LICENSE_CHECK_INTERVAL_MIN=15
GRACE_PERIOD_HOURS=72

# ─── OpenRouter AI ────────────────────────────────────────
OPENROUTER_API_KEY=CHANGE_ME_SHARED_BABAHDIGITAL_KEY

# ─── MT5 Bridge (Customer-specific) ───────────────────────
MT5_ZMQ_HOST=host.docker.internal
MT5_ZMQ_COMMAND_PORT=5555
MT5_ZMQ_DATA_PORT=5556

# ─── Telegram Bot (Customer-specific) ─────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME_FROM_BOTFATHER
REGISTRATION_CODE=CHANGE_ME_8_CHARS_RANDOM

# ─── Feature Flags (per tier) ─────────────────────────────
FAKE_LIQ_SHADOW_ENABLED=true
CONFLUENCE_TRACKING_ENABLED=true
ADVISOR_DAILY_LESSONS_ENABLED=true

# STARTER tier limits:
# FAKE_LIQ_STAGE_2_ENABLED=false
# CONFLUENCE_GATE_ENABLED=false

# TRADER tier:
FAKE_LIQ_STAGE_2_ENABLED=true
CONFLUENCE_GATE_ENABLED=false

# PREMIUM+ tier:
# FAKE_LIQ_STAGE_2_ENABLED=true
# CONFLUENCE_GATE_ENABLED=true
