generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(CLIENT)
  name          String?
  mt5Account    String?   @unique
  twoFaSecret   String?
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  licenses      License[]
  subscriptions Subscription[]
  sessions      Session[]
}

enum Role {
  ADMIN
  CLIENT
}

model License {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  licenseKey      String        @unique
  type            LicenseType
  vpsInstanceId   String?
  vpsInstance     VpsInstance?  @relation(fields: [vpsInstanceId], references: [id])
  status          LicenseStatus @default(PENDING)
  startsAt        DateTime
  expiresAt       DateTime
  autoRenew       Boolean       @default(false)
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now())
  revokedAt       DateTime?
  killSwitchEvents KillSwitchEvent[]
  auditLogs       AuditLog[]

  @@index([status, expiresAt])
  @@index([userId])
}

enum LicenseType {
  VPS_INSTALLATION
  PAMM_SUBSCRIBER
  SIGNAL_SUBSCRIBER
}

enum LicenseStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
  SUSPENDED
}

model VpsInstance {
  id                    String      @id @default(cuid())
  name                  String
  host                  String
  port                  Int         @default(8000)
  backendBaseUrl        String
  adminTokenCiphertext  String
  adminTokenIv          String
  adminTokenTag         String
  sshHost               String?
  sshPort               Int?        @default(1983)
  sshUser               String?
  status                VpsStatus   @default(PROVISIONING)
  lastHealthCheckAt     DateTime?
  lastHealthStatus      String?
  notes                 String?
  licenses              License[]
  healthChecks          HealthCheck[]
  createdAt             DateTime    @default(now())
}

enum VpsStatus {
  PROVISIONING
  ONLINE
  OFFLINE
  SUSPENDED
}

model Subscription {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  tier            SubscriptionTier
  status          LicenseStatus
  startsAt        DateTime
  expiresAt       DateTime
  profitSharePct  Decimal?         @db.Decimal(5, 2)
  monthlyFeeUsd   Decimal?         @db.Decimal(10, 2)
  brokerAccountId String?
  metadata        Json             @default("{}")
  createdAt       DateTime         @default(now())

  @@index([userId])
}

enum SubscriptionTier {
  PAMM_BASIC
  PAMM_PRO
  SIGNAL_BASIC
  SIGNAL_VIP
}

model KillSwitchEvent {
  id           String   @id @default(cuid())
  licenseId    String
  license      License  @relation(fields: [licenseId], references: [id])
  triggeredBy  String
  triggeredAt  DateTime @default(now())
  apiResponse  Json     @default("{}")
  success      Boolean
  errorMessage String?

  @@index([licenseId])
}

model HealthCheck {
  id             String      @id @default(cuid())
  vpsInstanceId  String
  vpsInstance    VpsInstance @relation(fields: [vpsInstanceId], references: [id])
  checkedAt      DateTime    @default(now())
  httpStatus     Int?
  responseTimeMs Int?
  zmqConnected   Boolean?
  dbOk           Boolean?
  lastTickAge    Float?
  raw            Json?

  @@index([vpsInstanceId, checkedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  licenseId  String?
  license    License? @relation(fields: [licenseId], references: [id])
  action     String
  ipAddress  String?
  userAgent  String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([licenseId, createdAt])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  jwtId        String    @unique
  refreshToken String    @unique
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?

  @@index([userId])
}

// =============================================
// CMS Models
// =============================================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string") // string, json, boolean, number
  updatedAt DateTime @updatedAt
}

model LandingSection {
  id          String   @id @default(cuid())
  slug        String   @unique // hero, performance, features, strategies, pricing, pairs, risk, how-it-works, testimonials, faq, cta, footer
  title       String
  subtitle    String?
  content     Json     @default("{}")
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([sortOrder])
}

model PricingTier {
  id          String   @id @default(cuid())
  slug        String   @unique // signal-basic, signal-vip, pamm-basic, pamm-pro, vps-license
  name        String
  price       String
  subtitle    String?
  features    Json     @default("[]") // string[]
  excluded    Json     @default("[]") // string[]
  note        String?
  ctaLabel    String   @default("Daftar")
  ctaLink     String   @default("/register")
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([sortOrder])
}

model Banner {
  id          String       @id @default(cuid())
  title       String
  content     String       @db.Text
  linkUrl     String?
  linkLabel   String?
  position    BannerPosition @default(TOP)
  bgColor     String?      @default("#0ea5e9")
  textColor   String?      @default("#ffffff")
  isActive    Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  updatedAt   DateTime     @updatedAt
  createdAt   DateTime     @default(now())

  @@index([isActive, startsAt, endsAt])
}

enum BannerPosition {
  TOP
  BOTTOM
  FLOATING
}

model Popup {
  id          String       @id @default(cuid())
  title       String
  content     String       @db.Text
  imageUrl    String?
  ctaLabel    String?
  ctaLink     String?
  trigger     PopupTrigger @default(DELAY)
  triggerValue String?     // delay_ms, scroll_pct, page_path
  isActive    Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  updatedAt   DateTime     @updatedAt
  createdAt   DateTime     @default(now())

  @@index([isActive])
}

enum PopupTrigger {
  DELAY
  EXIT_INTENT
  SCROLL
  PAGE_LOAD
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  FaqCategory @default(GENERAL)
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([category, sortOrder])
}

enum FaqCategory {
  GENERAL
  PRICING
  TECHNICAL
  SECURITY
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?  // e.g. "Trader, Jakarta"
  content   String   @db.Text
  rating    Int      @default(5) // 1-5
  avatarUrl String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([isVisible, sortOrder])
}

model PageMeta {
  id               String   @id @default(cuid())
  path             String   @unique // e.g. "/", "/register", "/register/signal"
  title            String
  description      String?  @db.Text
  ogTitle          String?
  ogDescription    String?  @db.Text
  ogImage          String?
  structuredData   Json?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Inquiry {
  id          String       @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  package     InquiryPackage @default(VPS_LICENSE)
  message     String       @db.Text
  status      InquiryStatus @default(NEW)
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, createdAt])
}

enum InquiryPackage {
  VPS_LICENSE
  PAMM
  SIGNAL
  OTHER
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
  REJECTED
}
