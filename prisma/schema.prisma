generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  role            Role      @default(CLIENT)
  name            String?
  mt5Account      String?   @unique
  twoFaSecret     String?
  twoFaEnabled    Boolean   @default(false)
  recoveryCodes   Json      @default("[]")
  telegramChatId  String?
  whatsappNumber  String?
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?
  licenses        License[]
  subscriptions   Subscription[]
  sessions        Session[]
}

enum Role {
  ADMIN
  CLIENT
}

model License {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  licenseKey      String        @unique
  type            LicenseType
  vpsInstanceId   String?
  vpsInstance     VpsInstance?  @relation(fields: [vpsInstanceId], references: [id])
  status          LicenseStatus @default(PENDING)
  startsAt        DateTime
  expiresAt       DateTime
  autoRenew       Boolean       @default(false)
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now())
  revokedAt       DateTime?
  killSwitchEvents KillSwitchEvent[]
  auditLogs       AuditLog[]

  @@index([status, expiresAt])
  @@index([userId])
}

enum LicenseType {
  VPS_INSTALLATION
  PAMM_SUBSCRIBER
  SIGNAL_SUBSCRIBER
}

enum LicenseStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
  SUSPENDED
}

model VpsInstance {
  id                    String      @id @default(cuid())
  name                  String
  customerCode          String?     @unique
  host                  String
  port                  Int         @default(8000)
  backendBaseUrl        String
  adminTokenCiphertext  String
  adminTokenIv          String
  adminTokenTag         String
  sshHost               String?
  sshPort               Int?        @default(1983)
  sshUser               String?
  status                VpsStatus   @default(PROVISIONING)
  lastHealthCheckAt     DateTime?
  lastHealthStatus      String?
  notes                 String?

  // VPS fleet management fields (Phase B)
  syncTokenCiphertext   String?
  syncTokenIv           String?
  syncTokenTag          String?
  codeVersion           String?
  lastSyncStatus        String?
  lastSyncAt            DateTime?
  seedChecksum          String?
  seedUrl               String?
  seedUrlExpiresAt      DateTime?

  licenses              License[]
  healthChecks          HealthCheck[]
  createdAt             DateTime    @default(now())
}

enum VpsStatus {
  PROVISIONING
  ONLINE
  OFFLINE
  SUSPENDED
}

model Subscription {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  tier            SubscriptionTier
  status          LicenseStatus
  startsAt        DateTime
  expiresAt       DateTime
  profitSharePct  Decimal?         @db.Decimal(5, 2)
  monthlyFeeUsd   Decimal?         @db.Decimal(10, 2)
  brokerAccountId String?
  metadata        Json             @default("{}")
  createdAt       DateTime         @default(now())

  @@index([userId])
}

enum SubscriptionTier {
  PAMM_BASIC
  PAMM_PRO
  SIGNAL_BASIC
  SIGNAL_VIP
}

model KillSwitchEvent {
  id           String   @id @default(cuid())
  licenseId    String
  license      License  @relation(fields: [licenseId], references: [id])
  triggeredBy  String
  triggeredAt  DateTime @default(now())
  apiResponse  Json     @default("{}")
  success      Boolean
  errorMessage String?

  @@index([licenseId])
}

model HealthCheck {
  id             String      @id @default(cuid())
  vpsInstanceId  String
  vpsInstance    VpsInstance @relation(fields: [vpsInstanceId], references: [id])
  checkedAt      DateTime    @default(now())
  httpStatus     Int?
  responseTimeMs Int?
  zmqConnected   Boolean?
  dbOk           Boolean?
  lastTickAge    Float?
  raw            Json?

  @@index([vpsInstanceId, checkedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  licenseId  String?
  license    License? @relation(fields: [licenseId], references: [id])
  action     String
  ipAddress  String?
  userAgent  String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([licenseId, createdAt])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  jwtId        String    @unique
  refreshToken String    @unique
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?

  @@index([userId])
}

// =============================================
// CMS Models
// =============================================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string") // string, json, boolean, number
  updatedAt DateTime @updatedAt
}

model LandingSection {
  id          String   @id @default(cuid())
  slug        String   @unique // hero, performance, features, strategies, pricing, pairs, risk, how-it-works, testimonials, faq, cta, footer
  title       String
  title_en    String?
  subtitle    String?
  subtitle_en String?
  content     Json     @default("{}")
  content_en  Json?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([sortOrder])
}

model PricingTier {
  id          String   @id @default(cuid())
  slug        String   @unique // signal-basic, signal-vip, pamm-basic, pamm-pro, vps-license
  name        String
  name_en     String?
  price       String
  subtitle    String?
  subtitle_en String?
  features    Json     @default("[]") // string[]
  features_en Json?
  excluded    Json     @default("[]") // string[]
  note        String?
  ctaLabel    String   @default("Daftar")
  ctaLabel_en String?
  ctaLink     String   @default("/register")
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([sortOrder])
}

model Banner {
  id          String       @id @default(cuid())
  title       String
  content     String       @db.Text
  linkUrl     String?
  linkLabel   String?
  position    BannerPosition @default(TOP)
  bgColor     String?      @default("#0ea5e9")
  textColor   String?      @default("#ffffff")
  isActive    Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  updatedAt   DateTime     @updatedAt
  createdAt   DateTime     @default(now())

  @@index([isActive, startsAt, endsAt])
}

enum BannerPosition {
  TOP
  BOTTOM
  FLOATING
}

model Popup {
  id          String       @id @default(cuid())
  title       String
  content     String       @db.Text
  imageUrl    String?
  ctaLabel    String?
  ctaLink     String?
  trigger     PopupTrigger @default(DELAY)
  triggerValue String?     // delay_ms, scroll_pct, page_path
  isActive    Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  updatedAt   DateTime     @updatedAt
  createdAt   DateTime     @default(now())

  @@index([isActive])
}

enum PopupTrigger {
  DELAY
  EXIT_INTENT
  SCROLL
  PAGE_LOAD
}

model Faq {
  id          String   @id @default(cuid())
  question    String
  question_en String?
  answer      String   @db.Text
  answer_en   String?  @db.Text
  category    FaqCategory @default(GENERAL)
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category, sortOrder])
}

enum FaqCategory {
  GENERAL
  PRICING
  TECHNICAL
  SECURITY
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?  // e.g. "Trader, Jakarta"
  content   String   @db.Text
  rating    Int      @default(5) // 1-5
  avatarUrl String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([isVisible, sortOrder])
}

model PageMeta {
  id               String   @id @default(cuid())
  path             String   @unique // e.g. "/", "/register", "/register/signal"
  title            String
  description      String?  @db.Text
  ogTitle          String?
  ogDescription    String?  @db.Text
  ogImage          String?
  structuredData   Json?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Inquiry {
  id          String       @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  package     InquiryPackage @default(VPS_LICENSE)
  message     String       @db.Text
  status      InquiryStatus @default(NEW)
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, createdAt])
}

enum InquiryPackage {
  VPS_LICENSE
  PAMM
  SIGNAL
  OTHER
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
  REJECTED
}

model PageContent {
  id          String   @id @default(cuid())
  slug        String   @unique // platform, platform-technology, solutions-signal, etc.
  title       String
  title_en    String?
  subtitle    String?
  subtitle_en String?
  body        String   @db.Text
  body_en     String?  @db.Text
  sections    Json     @default("[]") // Array of {heading, content} blocks
  sections_en Json?
  isVisible   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  title_en    String?
  excerpt     String        @db.Text
  excerpt_en  String?       @db.Text
  body        String        @db.Text
  body_en     String?       @db.Text
  category    ArticleCategory @default(RESEARCH)
  author      String        @default("Abdullah")
  readTime    Int           @default(5) // minutes
  imageUrl    String?
  isPublished Boolean       @default(false)
  publishedAt DateTime?
  updatedAt   DateTime      @updatedAt
  createdAt   DateTime      @default(now())
  sourceTopic BlogTopic?

  @@index([isPublished, publishedAt])
  @@index([category])
}

enum ArticleCategory {
  RESEARCH
  STRATEGY
  EXECUTION
  RISK
  OPERATIONS
  MARKET_ANALYSIS
  EDUCATION
  CASE_STUDY
  COMPLIANCE
}

// =============================================
// Blog Topic Catalog (AI auto-generation)
// =============================================
// Dynamic, DB-backed catalog of blog topics. Admin can add new topics
// (including future crypto topics via assetClass=CRYPTO) without code
// changes — the worker reads promptTemplate + dataSources from DB.
model BlogTopic {
  id                String          @id @default(cuid())
  slug              String          @unique
  titleId           String
  titleEn           String
  excerptId         String          @db.Text
  excerptEn         String          @db.Text
  promptTemplate    String          @db.Text
  dataSources       Json            @default("[]")
  keywords          Json            @default("[]")
  category          ArticleCategory @default(EDUCATION)
  assetClass        AssetClass      @default(FOREX)
  targetLengthWords Int             @default(1500)
  scheduledWeek     Int             @default(1)
  priority          Int             @default(0)
  status            BlogTopicStatus @default(PENDING)
  lastGeneratedAt   DateTime?
  lastError         String?         @db.Text
  aiModel           String?
  aiTokensUsed      Int             @default(0)
  articleId         String?         @unique
  article           Article?        @relation(fields: [articleId], references: [id], onDelete: SetNull)
  isActive          Boolean         @default(true)
  autoPublish       Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([status, scheduledWeek])
  @@index([isActive, priority])
  @@index([assetClass, isActive])
}

enum AssetClass {
  FOREX
  CRYPTO
  MULTI
}

enum BlogTopicStatus {
  PENDING
  GENERATING
  GENERATED
  PUBLISHED
  FAILED
  DISABLED
}

// =============================================
// Autonomy Layer — VPS1 integration
// =============================================

model ConsumerState {
  id          String   @id @default(cuid())
  scope       String   @unique
  lastSeenId  BigInt   @default(0)
  lastRunAt   DateTime?
  lastStatus  String?
  lastError   String?  @db.Text
  runCount    Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model SignalAuditLog {
  id                String    @id @default(cuid())
  sourceId          BigInt    @unique
  pair              String
  direction         String
  entryType         String?
  lot               Decimal?  @db.Decimal(10, 2)
  entryPrice        Decimal?  @db.Decimal(15, 5)
  stopLoss          Decimal?  @db.Decimal(15, 5)
  takeProfit        Decimal?  @db.Decimal(15, 5)
  confidence        Decimal?  @db.Decimal(4, 2)
  reasoning         String?   @db.Text
  indicatorSnapshot Json?
  emittedAt         DateTime
  outcome           SignalOutcome @default(PENDING)
  closePrice        Decimal?  @db.Decimal(15, 5)
  closeReason       String?
  profitUsd         Decimal?  @db.Decimal(12, 4)
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([pair, emittedAt])
  @@index([outcome, emittedAt])
  @@index([emittedAt])
}

enum SignalOutcome {
  PENDING
  OPEN
  WIN
  LOSS
  BREAKEVEN
  CANCELLED
}

model NotificationLog {
  id         String   @id @default(cuid())
  userId     String?
  channel    NotificationChannel
  category   String
  refId      String?
  payload    Json     @default("{}")
  status     NotificationStatus @default(PENDING)
  deliveredAt DateTime?
  errorMessage String? @db.Text
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum NotificationChannel {
  TELEGRAM
  EMAIL
  WHATSAPP
  INAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  channels  Json     @default("[\"INAPP\"]")
  minConfidence Decimal? @db.Decimal(4, 2)
  language  String   @default("id")
  timezone  String   @default("Asia/Jakarta")
  quietHoursStart String?
  quietHoursEnd   String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Invoice {
  id             String        @id @default(cuid())
  userId         String
  number         String        @unique
  amountUsd      Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         InvoiceStatus @default(DUE)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime
  paidAt         DateTime?
  description    String        @db.Text
  subscriptionId String?
  licenseId      String?
  periodStart    DateTime?
  periodEnd      DateTime?
  pdfUrl         String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, issuedAt])
  @@index([status, dueAt])
}

enum InvoiceStatus {
  DRAFT
  DUE
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Changelog {
  id          String   @id @default(cuid())
  version     String   @unique
  title       String
  title_en    String?
  body        String   @db.Text
  body_en     String?  @db.Text
  category    ChangelogCategory @default(FEATURE)
  releasedAt  DateTime
  isPublished Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([isPublished, releasedAt])
}

enum ChangelogCategory {
  FEATURE
  IMPROVEMENT
  FIX
  SECURITY
  BREAKING
}

model WorkerRun {
  id         String   @id @default(cuid())
  worker     String
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  status     String   @default("RUNNING")
  itemsProcessed Int  @default(0)
  errorMessage String? @db.Text
  metadata   Json     @default("{}")

  @@index([worker, startedAt])
}

// =============================================
// Pair Intelligence Brief
// =============================================

model PairBrief {
  id               String           @id @default(cuid())
  pair             String           // e.g. "BTCUSD"
  session          TradingSession
  date             DateTime         @db.Date
  slug             String           @unique // "btcusd-2026-04-19-asian"

  // Structured data from VPS1 (ground truth — never AI-generated)
  supportLevels    Json             @default("[]")  // number[]
  resistanceLevels Json             @default("[]")  // number[]
  sndZones         Json             @default("[]")  // {type,high,low,tf}[]
  confluenceScore  Decimal?         @db.Decimal(4, 2)
  fundamentalBias  String?          // "BULLISH" | "BEARISH" | "NEUTRAL"
  keyPatterns      Json             @default("[]")  // {name,tf,description}[]
  fakeLiquidity    Json             @default("[]")  // {level,type,strength}[]
  signalSnapshot   Json             @default("{}") // raw VPS1 signal data for audit

  // AI-generated narrative (bounded by structured data above)
  narrative        String           @db.Text
  narrative_en     String?          @db.Text
  tradeIdeas       Json             @default("[]")  // {direction,entry,sl,tp,rationale}[]

  // Access control
  accessTier       SubscriptionTier @default(SIGNAL_BASIC)

  // Meta
  aiModel          String?
  aiTokensUsed     Int              @default(0)
  validationStatus BriefValidation  @default(PENDING)
  validationErrors Json             @default("[]")
  isPublished      Boolean          @default(false)
  publishedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([pair, session, date])
  @@index([pair, date])
  @@index([isPublished, publishedAt])
}

enum TradingSession {
  ASIAN
  LONDON
  NEW_YORK
}

enum BriefValidation {
  PENDING
  PASSED
  FAILED
  MANUAL_REVIEW
}

model AiCallLog {
  id           String   @id @default(cuid())
  purpose      String   // "pair_brief_narrative", "pair_brief_translate"
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  latencyMs    Int      @default(0)
  success      Boolean
  errorMessage String?  @db.Text
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([purpose, createdAt])
}
